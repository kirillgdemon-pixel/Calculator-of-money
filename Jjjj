                let category = categorySelect ? categorySelect.value : '';

                if (isNaN(amount) || amount <= 0) { showToast('Введите корректную сумму'); return; }
                if (!account) { showToast('Выберите счёт'); return; }

                let toAccount = null;
                if (type === 'transfer') {
                    if (!toAccountSelect) { showToast('Выберите счёт-получатель'); return; }
                    toAccount = toAccountSelect.value;
                    if (!toAccount) { showToast('Выберите счёт-получатель'); return; }
