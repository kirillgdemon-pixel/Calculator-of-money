                        return;
                    }
                    newAcc.balance -= amount;
                    toAcc.balance += amount;
                }

                op.type = type;
                op.amount = amount;
                op.category = (type === 'transfer') ? '' : category;
                op.account = account;
                op.toAccount = (type === 'transfer') ? toAccount : undefined;
                op.comment = comment;

