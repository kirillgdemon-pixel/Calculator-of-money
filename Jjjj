                } else {
                    if (!category) { showToast('Выберите категорию'); return; }
                }

                const oldAcc = getAccount(op.account);
                if (oldAcc) {
                    if (op.type === 'income') oldAcc.balance -= op.amount;
                    else if (op.type === 'expense') oldAcc.balance += op.amount;
                    else if (op.type === 'transfer') {
                        oldAcc.balance += op.amount;
                        const oldToAcc = getAccount(op.toAccount);
                        if (oldToAcc) oldToAcc.balance -= op.amount;
                    }
