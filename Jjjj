            state.accounts.map(a => `<option value="${a.id}">${a.name} (${formatCurrency(a.balance)})</option>`).join('');

        openModal('Новая цель', `
            <div class="form-group"><label class="form-label">Название</label><input class="form-input" id="newGoalName" placeholder="Например: Ноутбук"></div>
            <div class="form-group"><label class="form-label">Целевая сумма</label><input class="form-input" type="number" id="newGoalTarget" step="0.01" placeholder="1000"></div>
            <div class="form-group"><label class="form-label">Начальная сумма (опционально)</label><input class="form-input" type="number" id="newGoalCurrent" step="0.01" value="0"></div>
            <div class="form-group">
                <label class="form-label">Счёт для пополнения</label>
                <select class="form-select" id="newGoalAccount">${accountOptions}</select>
            </div>
            <div class="btn-group">
                <button class="btn btn-outline" id="newGoalCancel">Отмена</button>
                <button class="btn btn-primary" id="newGoalSubmit">Создать</button>
            </div>
        `, { onClose: null });

        const newGoalCancel = document.getElementById('newGoalCancel');
        if (newGoalCancel) newGoalCancel.addEventListener('click', closeModal);
        
        const newGoalSubmit = document.getElementById('newGoalSubmit');
        if (newGoalSubmit) {
            newGoalSubmit.addEventListener('click', function() {
                const nameInput = document.getElementById('newGoalName');
                const targetInput = document.getElementById('newGoalTarget');
                const currentInput = document.getElementById('newGoalCurrent');
                const accountSelect = document.getElementById('newGoalAccount');
                
                if (!nameInput || !targetInput) return;
                const name = nameInput.value.trim();
                const target = parseFloat(targetInput.value);
                const current = currentInput ? parseFloat(currentInput.value) || 0 : 0;
                const accountId = accountSelect ? accountSelect.value : '';
                
                if (!name || isNaN(target) || target <= 0) { showToast('Введите корректные данные'); return; }
                if (!accountId) { showToast('Выберите счёт'); return; }
                state.goals.push({ id: generateId(), name, target, current, accountId });
                saveState();
                closeModal();
                renderAccounts();
                showToast(`Цель "${name}" создана`);
            });
        }
    }

    // ================================================================
    //  TABS (Accounts)
    // ================================================================
    document.querySelectorAll('#accountTabs .tab-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('#accountTabs .tab-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const tab = this.dataset.tab;
            const accountsContainer = document.getElementById('accountsContainer');
            const debtsContainer = document.getElementById('debtsContainer');
            const totalContainer = document.getElementById('totalContainer');
            if (accountsContainer) accountsContainer.style.display = tab === 'all' ? 'block' : 'none';
            if (debtsContainer) debtsContainer.style.display = tab === 'debts' ? 'block' : 'none';
            if (totalContainer) totalContainer.style.display = tab === 'total' ? 'block' : 'none';
        });
    });

    // ================================================================
    //  BOTTOM SHEET ACTIONS
    // ================================================================
    document.querySelectorAll('.sheet-option[data-action]').forEach(btn => {
        btn.addEventListener('click', function() {
            const action = this.dataset.action;
            closeBottomSheet();
            setTimeout(() => {
                if (action === 'account') createAccount();
                else if (action === 'operation') createOperation();
                else if (action === 'goal') createGoal();
                else if (action === 'category') createCategory();
            }, 350);
        });
    });

    const mainAddBtn = document.getElementById('mainAddBtn');
    if (mainAddBtn) mainAddBtn.addEventListener('click', openBottomSheet);
    
    const addCategoryBtn = document.getElementById('addCategoryBtn');
    if (addCategoryBtn) addCategoryBtn.addEventListener('click', createCategory);
    
    const addOperationBtn = document.getElementById('addOperationBtn');
    if (addOperationBtn) addOperationBtn.addEventListener('click', createOperation);

    // ================================================================
    //  SETTINGS: CURRENCY
    // ================================================================
    const currencyInput = document.getElementById('currencyInput');
    if (currencyInput) currencyInput.value = state.currency || '$';
    
    const saveCurrencyBtn = document.getElementById('saveCurrencyBtn');
    if (saveCurrencyBtn) {
        saveCurrencyBtn.addEventListener('click', function() {
            if (!currencyInput) return;
            const val = currencyInput.value.trim();
            if (val.length === 0) { showToast('Введите символ валюты'); return; }
            state.currency = val;
            saveState();
            renderAccounts();
            renderStatistics();
            showToast('Валюта сохранена');
        });
    }

    // ================================================================
    //  EXPORT / IMPORT
    // ================================================================
    const exportDataBtn = document.getElementById('exportDataBtn');
    if (exportDataBtn) {
        exportDataBtn.addEventListener('click', function() {
            const data = JSON.stringify(state, null, 2);
            const blob = new Blob([data], {type: 'application/json'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'sumlio_backup.json';
            a.click();
            URL.revokeObjectURL(url);
            showToast('Данные экспортированы');
        });
    }

    const importDataBtn = document.getElementById('importDataBtn');
    if (importDataBtn) {
        importDataBtn.addEventListener('click', function() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = function(e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function(ev) {
                    try {
                        const imported = JSON.parse(ev.target.result);
                        const required = ['accounts','categories','operations','goals','order','nextId'];
                        for (const key of required) {
                            if (!(key in imported)) {
                                showToast('Неверный формат файла');
                                return;
                            }
                        }
                        if (!imported.currency) imported.currency = '$';
                        state = imported;
                        saveState();
                        renderAccounts();
                        renderCategories();
                        renderOperations();
                        renderStatistics();
                        if (currencyInput) currencyInput.value = state.currency || '$';
                        showToast('Данные импортированы успешно');
                    } catch(err) {
                        showToast('Ошибка чтения файла');
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        });
    }

    // ================================================================
    //  RESET DATA
    // ================================================================
    const resetDataBtn = document.getElementById('resetDataBtn');
    if (resetDataBtn) {
        resetDataBtn.addEventListener('click', function() {
            if (confirm('Вы уверены, что хотите удалить ВСЕ данные?')) {
                if (confirm('Это действие необратимо!')) {
                    state = getEmptyState();
                    saveState();
                    renderAccounts();
                    renderCategories();
                    renderOperations();
                    renderStatistics();
                    if (currencyInput) currencyInput.value = state.currency || '$';
                    showToast('Все данные удалены');
                }
            }
        });
    }

    // ================================================================
    //  FILTER EVENTS
    // ================================================================
    const filterType = document.getElementById('filterType');
    const filterCategory = document.getElementById('filterCategory');
    const filterAccount = document.getElementById('filterAccount');
    const filterSearch = document.getElementById('filterSearch');
    
    if (filterType) filterType.addEventListener('change', renderOperations);
    if (filterCategory) filterCategory.addEventListener('change', renderOperations);
    if (filterAccount) filterAccount.addEventListener('change', renderOperations);
    if (filterSearch) filterSearch.addEventListener('input', renderOperations);

    // ================================================================
    //  WINDOW RESIZE
    // ================================================================
    let resizeTimeout;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            if (currentScreen === 'screenStatistics') renderStatistics();
        }, 300);
    });

    // ================================================================
    //  INIT
    // ================================================================
    function updateClock() {
        const now = new Date();
        const headerTime = document.getElementById('headerTime');
        if (headerTime) {
            headerTime.textContent = String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
        }
    }
    updateClock();
    setInterval(updateClock, 60000);

    renderAccounts();
    renderCategories();
    renderOperations();
    renderStatistics();
    navigateTo('screenAccounts');

    console.log('✅ Sumlio v2.0 — полностью исправленная версия');
    console.log('📊 Данных:', { accounts: state.accounts.length, categories: state.categories.length, operations: state.operations.length, goals: state.goals.length });
});
</script>
</body>
</html>
